# Copy this file to `.env` and fill in the keys you actually want to use.
# You can leave either key blank; the app will still run for ingestion/indexing,
# but answer generation will be disabled if no provider is configured.

# --- Gemini (default) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- OpenAI (optional fallback) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Embedding model (local, no key required) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval ---
TOP_K=4
# Below this similarity score, the pipeline says it cannot find enough evidence.
MIN_SCORE=0.25

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MIN_CHUNK_SIZE=250
